{
  "name": "th-player",
  "version": "0.0.2",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:ci": "ng build --configuration production --base-href /th-player/",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:run": "ng test --watch=false",
    "test:ci": "ng test --watch=false --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,md,html,scss,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,md,html,scss,json}\"",
    "type-check": "tsc --noEmit",
    "pre-commit": "lint-staged && npm run test:ci",
    "prepare": "husky"
  },
  "private": true,
  "packageManager": "npm@11.9.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.14",
    "@angular/cli": "^21.2.14",
    "@angular/compiler-cli": "^21.2.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.0.8"
  }
}
